  ────────────────────────────────────────────────
-- ============================================================
--  WRRB – Warehouse Inspection System
--  Database Schema
--  Engine: MySQL 5.7+
-- ============================================================

CREATE DATABASE IF NOT EXISTS wrrb_system
  CHARACTER SET utf8mb4
  COLLATE utf8mb4_unicode_ci;

USE wrrb_system;

-- ============================================================
--  USERS
-- ============================================================
CREATE TABLE users (
  id            INT UNSIGNED    AUTO_INCREMENT PRIMARY KEY,
  full_name     VARCHAR(150)    NOT NULL,
  email         VARCHAR(150)    NOT NULL UNIQUE,
  phone         VARCHAR(20)     NOT NULL,
  password_hash VARCHAR(255)    NOT NULL,
  role          ENUM('regulator','admin','inspector','operator') NOT NULL,
  profile_photo VARCHAR(255)    DEFAULT NULL,
  status        ENUM('active','inactive') NOT NULL DEFAULT 'active',
  created_by    INT UNSIGNED    DEFAULT NULL,          -- who created this user
  created_at    TIMESTAMP       DEFAULT CURRENT_TIMESTAMP,
  updated_at    TIMESTAMP       DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (created_by) REFERENCES users(id) ON DELETE SET NULL
) ENGINE=InnoDB;

-- ============================================================
--  WAREHOUSES
-- ============================================================
CREATE TABLE warehouses (
  id            INT UNSIGNED    AUTO_INCREMENT PRIMARY KEY,
  operator_id   INT UNSIGNED    NOT NULL,
  name          VARCHAR(200)    NOT NULL,
  district      VARCHAR(100)    NOT NULL,
  region        VARCHAR(100)    NOT NULL,
  ward          VARCHAR(100)    NOT NULL,
  street        VARCHAR(100)    NOT NULL,
  gps_lat       DECIMAL(10,7)   NOT NULL,
  gps_lng       DECIMAL(10,7)   NOT NULL,
  capacity      ENUM('> 5000 MT','1000-4999 MT','200-999 MT') NOT NULL,
  in_operation  ENUM('Yes','No') NOT NULL,
  status        ENUM('pending','approved','rejected','conditional') NOT NULL DEFAULT 'pending',
  created_at    TIMESTAMP       DEFAULT CURRENT_TIMESTAMP,
  updated_at    TIMESTAMP       DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (operator_id) REFERENCES users(id) ON DELETE CASCADE
) ENGINE=InnoDB;

-- ============================================================
--  INSPECTION REQUESTS
-- ============================================================
CREATE TABLE inspection_requests (
  id            INT UNSIGNED    AUTO_INCREMENT PRIMARY KEY,
  warehouse_id  INT UNSIGNED    NOT NULL,
  requested_by  INT UNSIGNED    NOT NULL,              -- operator user id
  preferred_date DATE           DEFAULT NULL,
  notes         TEXT            DEFAULT NULL,
  status        ENUM('pending','assigned','completed') NOT NULL DEFAULT 'pending',
  created_at    TIMESTAMP       DEFAULT CURRENT_TIMESTAMP,
  updated_at    TIMESTAMP       DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (warehouse_id)  REFERENCES warehouses(id) ON DELETE CASCADE,
  FOREIGN KEY (requested_by)  REFERENCES users(id)      ON DELETE CASCADE
) ENGINE=InnoDB;

-- ============================================================
--  INSPECTIONS
-- ============================================================
CREATE TABLE inspections (
  id              INT UNSIGNED    AUTO_INCREMENT PRIMARY KEY,
  request_id      INT UNSIGNED    NOT NULL,
  warehouse_id    INT UNSIGNED    NOT NULL,
  inspector_id    INT UNSIGNED    NOT NULL,
  assigned_by     INT UNSIGNED    NOT NULL,             -- admin who assigned
  scheduled_date  DATE            NOT NULL,
  inspector_name  VARCHAR(150)    DEFAULT NULL,
  inspection_date DATE            DEFAULT NULL,
  -- GPS captured by inspector on arrival
  inspector_lat   DECIMAL(10,7)   DEFAULT NULL,
  inspector_lng   DECIMAL(10,7)   DEFAULT NULL,
  gps_verified    TINYINT(1)      DEFAULT 0,            -- 1 = within range
  gps_distance_m  DECIMAL(10,2)   DEFAULT NULL,         -- distance in metres
  -- Scoring
  score_pts       DECIMAL(6,2)    DEFAULT NULL,
  max_pts         DECIMAL(6,2)    DEFAULT NULL,
  score_pct       DECIMAL(5,2)    DEFAULT NULL,
  qualified       TINYINT(1)      DEFAULT NULL,         -- 1=pass, 0=fail
  -- Signature
  signature_data  LONGTEXT        DEFAULT NULL,         -- base64 canvas image
  -- Status
  status          ENUM('assigned','in_progress','scored','completed') NOT NULL DEFAULT 'assigned',
  -- Regulator decision
  decision        ENUM('approved','rejected','conditional') DEFAULT NULL,
  decision_comment TEXT           DEFAULT NULL,
  recommendations TEXT            DEFAULT NULL,         -- regulator recommendations
  decided_by      INT UNSIGNED    DEFAULT NULL,
  decided_at      TIMESTAMP       NULL DEFAULT NULL,
  created_at      TIMESTAMP       DEFAULT CURRENT_TIMESTAMP,

  ... (189 more lines)

