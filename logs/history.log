SAVE_DIR = os.path.expanduser("~/Downloads/jarvis_scraped")


def _ts() -> str:
    return datetime.now().strftime("%Y%m%d_%H%M%S")


def _ensure_save_dir():
    os.makedirs(SAVE_DIR, exist_ok=True)


def _check_playwright() -> str | None:
